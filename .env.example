# Optional API keys. Only set the ones you actually want to use.
# Copy this file to `.env` and fill in. `.env` is gitignored.

# Required when running the CLI locally (not needed inside GitHub Actions,
# where GITHUB_TOKEN is auto-injected). Get a token from:
#   gh auth token
# Or create a personal access token with `models:read` permission.
GITHUB_TOKEN=

# Optional. Enables image generation in the polish skill via OpenAI's
# gpt-image-2 model. Without it, posts still work, just no images.
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional. Enables video generation in the polish skill via Replicate.
# Without it, posts and images still work, just no videos.
# Get one at: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=
