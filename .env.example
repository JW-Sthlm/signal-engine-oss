# Optional API keys. Only set the ones you actually want to use.
# Copy this file to `.env` and fill in. `.env` is gitignored.

# Required when running the CLI locally (not needed inside GitHub Actions,
# where GITHUB_TOKEN is auto-injected). Get a token from:
#   gh auth token
# Or create a personal access token with `models:read` permission.
GITHUB_TOKEN=

# Optional. Enables image generation in the polish skill via OpenAI's
# gpt-image-2 model. Without it, posts still work, just no images.
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional. Enables video generation in the polish skill via Replicate.
# Without it, posts and images still work, just no videos.
# Get one at: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=

# --- LinkedIn integration (optional) -------------------------------------
# Enables `scripts/linkedin_post.py` to push polished posts straight to your
# LinkedIn drafts tab (or publish live with --publish). Run linkedin_auth.py
# once to set up the access token and author URN automatically.
#
# Setup:
#   1. Create a LinkedIn Developer App at https://www.linkedin.com/developers/apps
#   2. Under "Auth" → add redirect URL: http://localhost:8765/callback
#   3. Under "Products" → request "Sign In with LinkedIn using OpenID Connect"
#      and "Share on LinkedIn" (auto-approved usually)
#   4. Copy Client ID and Secret from the Auth tab into the two vars below
#   5. Run: python scripts/linkedin_auth.py
#   6. The auth script fills in ACCESS_TOKEN and AUTHOR_URN automatically
#
# Tokens expire every 60 days. Re-run linkedin_auth.py when posts start failing.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=

# --- PDF carousel (optional) ---------------------------------------------
# `scripts/generate_pdf.py` turns a polished post markdown file into a
# square 1080x1080 multi-page PDF, suitable for a LinkedIn document/carousel.
# These four vars set the branding shown on the cover and CTA pages. All
# can also be overridden per run with CLI flags.
SIGNAL_BRAND=signal-engine-oss
SIGNAL_CTA_LINE=Make your radar yours.
SIGNAL_CTA_URL=github.com/JW-Sthlm/signal-engine-oss
SIGNAL_PDF_THEME=dark

# --- Podcast transcription (optional) ------------------------------------
# When set to `auto` or `all`, podcast items in your RSS feeds get
# transcribed before scoring so the model has real content to grip,
# not just a teaser. Requires the `podcast-transcriber` package and a
# matching API key. See requirements.txt for install variants.
#
#   none  - skip transcription (default; same as unset)
#   auto  - transcribe only items with thin (<400 char) summaries
#   all   - transcribe every podcast item
#
# Bounded to 5 items per run so a single cron doesn't break the bank.
# Transcripts are cached at `_workdir/transcripts/` so re-runs are free.
SIGNAL_TRANSCRIBE_PODCASTS=none

# Pick ONE tier:
#   GOOGLE_API_KEY — uses Gemini (fast, free quota, great quality)
#   OPENAI_API_KEY — uses Whisper API (already set above for image gen)
GOOGLE_API_KEY=
