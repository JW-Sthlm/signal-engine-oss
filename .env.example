# Optional API keys. Only set the ones you actually want to use.
# Copy this file to `.env` and fill in. `.env` is gitignored.

# Required when running the CLI locally (not needed inside GitHub Actions,
# where GITHUB_TOKEN is auto-injected). Get a token from:
#   gh auth token
# Or create a personal access token with `models:read` permission.
GITHUB_TOKEN=

# Optional. Enables image generation in the polish skill via OpenAI's
# gpt-image-2 model. Without it, posts still work, just no images.
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional. Enables video generation in the polish skill via Replicate.
# Without it, posts and images still work, just no videos.
# Get one at: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=

# --- LinkedIn integration (optional) -------------------------------------
# Enables `scripts/linkedin_post.py` to push polished posts straight to your
# LinkedIn drafts tab (or publish live with --publish). Run linkedin_auth.py
# once to set up the access token and author URN automatically.
#
# Setup:
#   1. Create a LinkedIn Developer App at https://www.linkedin.com/developers/apps
#   2. Under "Auth" → add redirect URL: http://localhost:8765/callback
#   3. Under "Products" → request "Sign In with LinkedIn using OpenID Connect"
#      and "Share on LinkedIn" (auto-approved usually)
#   4. Copy Client ID and Secret from the Auth tab into the two vars below
#   5. Run: python scripts/linkedin_auth.py
#   6. The auth script fills in ACCESS_TOKEN and AUTHOR_URN automatically
#
# Tokens expire every 60 days. Re-run linkedin_auth.py when posts start failing.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=
